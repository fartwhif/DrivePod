generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:../../data/database.db"
}

model Channel {
  id               String   @id @default(cuid())
  channelId        String   @unique
  title            String
  order            Int      @default(0)
  ignoreScrapeDone Boolean  @default(false)
  createdAt        DateTime @default(now())
  videos           Video[]

  @@index([order])
}

model Video {
  id            String   @id @default(cuid())
  videoId       String   @unique
  channelId     String
  title         String
  description   String?
  publishedAt   DateTime
  thumbnailPath String?
  audioPath     String
  subtitlePath  String?
  watched       Boolean  @default(false)
  progress      Float    @default(0)
  duration      Float?
  ignored       Boolean  @default(false)
  createdAt     DateTime @default(now())

  channel       Channel  @relation(fields: [channelId], references: [channelId])

  @@index([publishedAt])
  @@index([watched])
  @@index([ignored])
  @@index([channelId, ignored])   // ← critical for fast per-channel ignored checks
}

model Config {
  id    String @id @default(cuid())
  key   String @unique
  value String
}